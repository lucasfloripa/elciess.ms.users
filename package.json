{
  "name": "elciess.ms.users",
  "version": "1.0.0",
  "description": "API to register users to be used in any Elciess services.",
  "author": "Lucas Gonçalves",
  "repository": "https://github.com/lucasfloripa/elciess.ms.users",
  "scripts": {
    "start:dev": "NODE_ENV=dev nodemon --watch './**/*.ts' --exec 'ts-node -r tsconfig-paths/register ./src/main/server.ts' ./src/main/server.ts",
    "build": "rimraf dist && tsc -p tsconfig-build.json",
    "test": "jest --passWithNoTests --runInBand --no-cache",
    "test:unit": "npm test -- --watchAll -c jest-unit.config.js",
    "test:e2e": "npm test -- --watch -c jest-e2e.config.js",
    "test:staged": "npm test -- --findRelatedTests",
    "test:ci": "npm test -- --coverage",
    "prepare": "husky install"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "kafkajs": "^2.2.3",
    "module-alias": "^2.2.2",
    "pg": "^8.8.0",
    "uuid": "^9.0.0",
    "validator": "^13.7.0"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^17.4.2",
    "@faker-js/faker": "^7.6.0",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.16",
    "@types/jest": "^29.2.5",
    "@types/kafkajs": "^1.9.0",
    "@types/module-alias": "^2.0.1",
    "@types/node": "^18.11.18",
    "@types/pg": "^8.6.6",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^9.0.0",
    "@types/validator": "^13.7.11",
    "@typescript-eslint/eslint-plugin": "^5.48.1",
    "commitlint": "^17.4.2",
    "eslint": "^8.31.0",
    "eslint-config-standard-with-typescript": "^27.0.1",
    "eslint-plugin-import": "^2.27.4",
    "eslint-plugin-n": "^15.6.1",
    "eslint-plugin-promise": "^6.1.1",
    "husky": "^8.0.0",
    "jest": "^29.3.1",
    "lint-staged": "^13.1.0",
    "nodemon": "^2.0.20",
    "rimraf": "^4.0.4",
    "supertest": "^6.3.3",
    "ts-jest": "^29.0.5",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.1.2",
    "tscpaths": "^0.0.9",
    "typescript": "^4.9.4"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint 'src/**' --fix",
      "npm run test:staged",
      "git add"
    ]
  }
}
